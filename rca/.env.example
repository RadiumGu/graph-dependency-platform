# .env.example — copy to .env and fill in your values
# This file is safe to commit. Never commit the actual .env.

# AWS account and region
ACCOUNT=<YOUR_AWS_ACCOUNT_ID>
REGION=ap-northeast-1

# Lambda function settings
FUNCTION_NAME=rca-engine
ROLE_ARN=arn:aws:iam::<YOUR_AWS_ACCOUNT_ID>:role/<YOUR_LAMBDA_ROLE>

# VPC settings (required for Neptune access)
SUBNET_IDS=subnet-<id1>,subnet-<id2>
SG_IDS=sg-<id>

# Neptune
NEPTUNE_ENDPOINT=<YOUR_NEPTUNE_CLUSTER_ENDPOINT>
NEPTUNE_PORT=8182

# EKS cluster name
EKS_CLUSTER=<YOUR_EKS_CLUSTER_NAME>

# DeepFlow / ClickHouse
CLICKHOUSE_HOST=<YOUR_CLICKHOUSE_HOST>
CLICKHOUSE_PORT=8123

# Bedrock
BEDROCK_MODEL=global.anthropic.claude-sonnet-4-6
BEDROCK_KB_ID=<YOUR_BEDROCK_KNOWLEDGE_BASE_ID>

# SNS topic name (will be created if not exists)
SNS_TOPIC_NAME=rca-alerts

# Slack (webhook stored in SSM)
SSM_SLACK_WEBHOOK_PATH=/rca/slack/webhook
SLACK_CHANNEL=#rca-alerts
