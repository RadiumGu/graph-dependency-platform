# graph-dp-cdk environment variables
# Copy this file to .env and fill in your actual values.
# .env is gitignored and must never be committed.

# ─── CDK Deployment ───────────────────────────────────────────────────────────
# AWS Account ID for CDK deployment
CDK_ACCOUNT_ID=YOUR_AWS_ACCOUNT_ID

# AWS Region for CDK deployment
CDK_REGION=YOUR_AWS_REGION

# ─── Neptune ──────────────────────────────────────────────────────────────────
# Neptune cluster endpoint (writer endpoint)
# Example: mycluster.cluster-xxxxxxxxxxxx.us-east-1.neptune.amazonaws.com
NEPTUNE_ENDPOINT=YOUR_NEPTUNE_CLUSTER_ENDPOINT
NEPTUNE_PORT=8182

# ─── ClickHouse / DeepFlow ────────────────────────────────────────────────────
# ClickHouse host IP or hostname (inside the VPC)
CLICKHOUSE_HOST=YOUR_CLICKHOUSE_HOST_IP
CLICKHOUSE_PORT=8123

# ─── EKS ──────────────────────────────────────────────────────────────────────
# EKS cluster name (used by etl_aws Lambda)
EKS_CLUSTER_NAME=YOUR_EKS_CLUSTER_NAME

# ─── VPC / Networking ─────────────────────────────────────────────────────────
# VPC ID that Neptune and Lambda are deployed in
VPC_ID=YOUR_VPC_ID

# Security Group ID for Lambda functions that access Neptune
LAMBDA_SG_ID=YOUR_LAMBDA_SG_ID

# ─── CloudFormation Stacks ────────────────────────────────────────────────────
# Comma-separated list of CFN stack names to watch for ETL trigger
CFN_STACK_NAMES=YOUR_CFN_STACK1,YOUR_CFN_STACK2
