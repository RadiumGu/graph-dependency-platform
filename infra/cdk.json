{
  "app": "npx ts-node --prefer-ts-exts bin/graph-dp.ts",
  "watch": {
    "include": ["**"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "**/*.d.ts",
      "**/*.js",
      "tsconfig.json",
      "package*.json",
      "yarn.lock",
      "node_modules",
      "test"
    ]
  },
  "context": {
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/core:checkSecretUsage": true,
    "@aws-cdk/core:target-partitions": ["aws", "aws-cn"],
    "vpcId": "YOUR_VPC_ID",
    "lambdaSgId": "YOUR_LAMBDA_SG_ID",
    "neptuneEndpoint": "YOUR_NEPTUNE_CLUSTER_ENDPOINT",
    "neptunePort": "8182",
    "clickhouseHost": "YOUR_CLICKHOUSE_HOST_IP",
    "eksClusterName": "YOUR_EKS_CLUSTER_NAME",
    "cfnStackNames": "YOUR_CFN_STACK1,YOUR_CFN_STACK2"
  }
}
